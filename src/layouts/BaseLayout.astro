---
import "../styles/global.css"
import Meta from "../components/Meta.astro"
import Header from "../components/Header"
import Footer from "../components/Footer"

interface Props {
	title?: string
	description?: string
	image?: string
	type?: "website" | "article"
	date?: string
}

const { title, description, image, type, date } = Astro.props
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="stylesheet" href="/src/styles/global.css" />
		<link
			rel="alternate"
			type="application/rss+xml"
			title="thoughts RSS feed"
			href={new URL("/rss.xml", Astro.site)}
		/>
		<Meta {title} {description} {type} {date} />
	</head>
	<body class="bg-white text-neutral-900 min-h-screen flex flex-col">
		<Header />
		<section class="md:w-3xl mx-auto pt-0 p-4 md:p-0 grow">
			<slot />
		</section>
		<Footer />
	</body>
</html>
